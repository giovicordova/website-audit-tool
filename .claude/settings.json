{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(scripts/lighthouse.sh *)",
      "Bash(python scripts/score.py *)",
      "Bash(python3 scripts/score.py *)",
      "Bash(tests/test-*)",
      "Bash(scripts/perplexity-check.sh *)"
    ],
    "deny": [
      "Bash(curl * -X POST *)",
      "Bash(curl * --upload-file *)",
      "Bash(curl * -T *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-report-name.sh"
          }
        ]
      }
    ]
  }
}
